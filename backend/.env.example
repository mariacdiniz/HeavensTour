NODE_ENV=development
PORT=3333

MONGO_URI=mongodb://localhost:27017/heavenstour

JWT_SECRET=altere-esta-chave-em-producao-min-32-chars
JWT_EXPIRES_IN=7d

# Uma ou várias URLs separadas por vírgula (CORS do React)
FRONTEND_URL=http://localhost:5173
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# local = pasta uploads/ | s3 = AWS ou LocalStack
UPLOAD_MODE=local
UPLOAD_DIR=uploads

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT=http://localhost:4566
# No Docker use http://localhost:4566 para URLs retornadas ao front (hostname do navegador)
AWS_PUBLIC_ENDPOINT=http://localhost:4566
AWS_BUCKET=heavens-tour-aircraft
AWS_FORCE_PATH_STYLE=true

LOG_LEVEL=info
